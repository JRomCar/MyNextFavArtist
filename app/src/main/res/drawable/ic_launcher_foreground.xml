<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground: four bars of a sound level meter, echoing the skeleton loader the
  list screens use. A waveform stays readable at 48dp where a musical note or a vinyl groove
  turns to mush, and it avoids the note/heart silhouette every other music app already owns.

  Geometry: a 108x108 adaptive-icon viewport only guarantees the centre 66x66 is unmasked, so
  every bar - including the round stroke caps, which extend half a stroke width past each
  endpoint - stays inside a radius of 33 from centre (54,54). The furthest point of the outer
  bars is ~28 out, leaving room for the parallax launchers apply on top.

  Drawn as stroked lines rather than filled rectangles so android:strokeLineCap gives the
  rounded ends for free, instead of hand-writing arc path data for sixteen corners.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:pathData="M33.75,45.5 L33.75,62.5"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round" />
    <path
        android:pathData="M47.25,36.5 L47.25,71.5"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round" />
    <path
        android:pathData="M60.75,41.5 L60.75,66.5"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round" />
    <path
        android:pathData="M74.25,49.5 L74.25,58.5"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round" />
</vector>
