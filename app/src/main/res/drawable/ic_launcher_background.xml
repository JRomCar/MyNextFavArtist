<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon background: the app's brand gradient, violet (Violet40) to magenta (Magenta40),
  the same pair the theme uses for primary and tertiary. Drawn corner to corner so the diagonal
  survives whatever mask the launcher applies - circle, squircle or rounded square.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item
                    android:color="#FF5B3DF5"
                    android:offset="0" />
                <item
                    android:color="#FFE0316E"
                    android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
